# EduAI P2 — environment değişkenleri şablonu
# Kullanım: bu dosyayı `.env` olarak kopyala ve değerleri doldur.
# `.env` dosyası .gitignore tarafından yok sayılır; sakın commit'leme.

# --- Sentetik veri üretimi (data_prep.py Seçenek A için zorunlu) ---
# Claude API ile Türkçe Q&A üretimi. https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Hugging Face Hub (opsiyonel) ---
# Private model/dataset indirmek veya fine-tuned adapter'ı push etmek için.
# https://huggingface.co/settings/tokens
HF_TOKEN=

# --- MLflow remote tracking (opsiyonel) ---
# Lokal tracking için boş bırak (config.yaml tracking_uri devreye girer).
# Remote MLflow server kullanıyorsan aç.
# MLFLOW_TRACKING_URI=
# MLFLOW_TRACKING_USERNAME=
# MLFLOW_TRACKING_PASSWORD=
