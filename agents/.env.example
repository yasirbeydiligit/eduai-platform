# Agents (P3) ortam değişkenleri — gerçek değerleri `.env`'e yaz, bu dosyayı commit etme.
# pipeline.py başlangıçta birden fazla yolu dener; ilk var olan .env yüklenir:
#   1. agents/.env       (bu dizin — tercih edilen)
#   2. <repo_root>/.env
#   3. ml/.env           (P2'den kalan; geriye uyum için)

# --- LLM backend seçimi ---
# anthropic   → claude-haiku-4-5 (dev için tercih, Task 3-4-5)
# qwen3-local → P2 LoRA adapter (Linux/CUDA only, Task 5+'da)
# vllm        → vLLM serving endpoint (production gateway)
LLM_BACKEND=anthropic

# Anthropic API anahtarı (LLM_BACKEND=anthropic için zorunlu).
# https://console.anthropic.com/ adresinden alınabilir.
ANTHROPIC_API_KEY=sk-ant-...

# Default Anthropic modeli — Task 3 dev rehberi (claude-haiku-4-5 hızlı + ucuz).
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Embedding ---
# F-1 Sapma 7 default; emrecan'a fallback için override (sadece test).
# EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- Qdrant ---
# Docker compose'da api → qdrant servisi; lokal development'ta localhost.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=eduai_documents
